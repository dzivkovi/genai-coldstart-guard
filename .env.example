# genai-coldstart-guard configuration
# Copy to .env and fill in your values. Never commit .env (it is gitignored).

# Honor the mock:* simulation routes. Dispatch is driven per-request by the `route` field:
# no route hits the real endpoint; a "mock:*" route is a simulation, allowed only when this is true.
# The code default is false (secure by default); this quickstart file turns it on for local demos.
MOCK_ENABLED=true

# true  = always return HTTP 200, real status goes in the payload's `status` (legacy Java client expects 200s)
# false = emit real HTTP status codes on the wire
COMPATIBILITY_HTTP_200=true

# Retry-After hint (seconds) sent with warming / 503 responses
RETRY_AFTER_SECONDS=60


# --- Databricks backend (used by empty-route / real requests) ---

# Workspace URL. AWS: https://<id>.cloud.databricks.com   Azure: https://adb-<id>.azuredatabricks.net
DATABRICKS_HOST=https://<your-workspace>.cloud.databricks.com

# The serving endpoint to guard: a scale-to-zero custom model (here an MLflow echo/fortune pyfunc)
DATABRICKS_ENDPOINT_NAME=coldstart-echo-fortune

# Read timeout for the /invocations call (seconds). Keep it above your warm-latency ceiling.
DATABRICKS_TIMEOUT_SECONDS=30


# --- Auth: choose ONE method ---

# Method 1 - Personal Access Token (simplest, but a long-lived secret).
#   Paste a PAT below and rotate/revoke it when done. Leave blank if using Method 2.
DATABRICKS_TOKEN=

# Method 2 - OAuth machine-to-machine / service principal (recommended: no long-lived secret in .env).
#   Set the two values below, then run:   source scripts/get_databricks_token.sh
#   That exchanges them for a short-lived token (~1h) and exports DATABRICKS_TOKEN for you.
DATABRICKS_CLIENT_ID=
DATABRICKS_CLIENT_SECRET=

# Method 3 - a profile already in ~/.databrickscfg (the office path: no PATs; the profile holds the
#   service-principal client_id/secret or an OAuth login). Nothing goes in .env - just run:
#     source scripts/get_databricks_token.sh <profile>
#   The Databricks CLI mints a short-lived token from the profile and exports DATABRICKS_TOKEN.


# --- Mock tuning (only read when MOCK_ENABLED=true) ---

# Artificial delay on mock responses (seconds)
MOCK_SLEEP_SECONDS=0

# Stateful mock:cold_start route - warm for this long, become ready, then cold again after this much idle.
MOCK_WARMUP_SECONDS=10
MOCK_IDLE_RESET_SECONDS=30
