# mock or databricks
BACKEND_MODE=mock

# true = always return HTTP 200 and put real status in payload
# false = return real HTTP status codes
COMPATIBILITY_HTTP_200=true

# Databricks mode
DATABRICKS_HOST=https://adb-xxxx.azuredatabricks.net
DATABRICKS_TOKEN=
DATABRICKS_ENDPOINT_NAME=
DATABRICKS_TIMEOUT_SECONDS=30

# Response hint
RETRY_AFTER_SECONDS=60

# Optional mock delay
MOCK_SLEEP_SECONDS=0
